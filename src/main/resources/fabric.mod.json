{
  "schemaVersion": 1,
  "id": "visualclient",
  "version": "${version}",
  "name": "Visual Client",
  "description": "Client-side cosmetic visuals with custom GUI foundations.",
  "authors": [
    "You"
  ],
  "license": "MIT",
  "environment": "client",
  "entrypoints": {
    "client": [
      {
        "value": "com.visualproject.client.VisualClientMod",
        "adapter": "kotlin"
      }
    ]
  },
  "mixins": [
    "visualclient.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.18.4",
    "minecraft": "~1.21.11",
    "java": ">=21",
    "fabric-api": ">=0.141.3+1.21.11",
    "fabric-language-kotlin": ">=1.13.9+kotlin.2.3.10"
  }
}
